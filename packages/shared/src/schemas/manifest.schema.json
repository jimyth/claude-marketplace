{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExtensionManifest",
  "type": "object",
  "required": ["id", "name", "version", "type", "author", "description"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique identifier (kebab-case)"
    },
    "name": {
      "type": "string",
      "description": "Display name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (e.g., 1.0.0)"
    },
    "type": {
      "type": "string",
      "enum": ["skill", "plugin"],
      "description": "Extension type"
    },
    "author": {
      "type": "string",
      "description": "Author name or username"
    },
    "description": {
      "type": "string",
      "description": "Brief description"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags for search"
    },
    "entry": {
      "type": "string",
      "description": "Main file (default: SKILL.md or PLUGIN.md)"
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "file"],
        "properties": {
          "id": { "type": "string" },
          "file": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "description": "Sub-commands"
    },
    "changelog": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["version", "date"],
        "properties": {
          "version": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "changes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "description": "Version history"
    }
  }
}
